# 默认自选股代码（逗号分隔），如不通过 API 传 symbols 则使用此列表
STOCK_SYMBOLS_DEFAULT=600519,000001,300750

# 飞书 / 钉钉 Webhook（可选，供 OpenClaw 或本服务推送日报）
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxx
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# 服务端口（可选，默认 8000）
# PORT=8000

# 大模型（默认 DeepSeek，兼容 OpenAI 格式；可换通义等）
OPENAI_API_BASE=https://api.deepseek.com
# OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=deepseek-chat
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_RETRIES=2

# 模拟盘 API（宽易/掘金等，后续真实交易换配置）
# SIM_BROKER_BASE_URL=https://xxx
# SIM_BROKER_API_KEY=xxx
# 实盘券商（broker_live 占位，对接后填入）
# REAL_BROKER_BASE_URL=
# REAL_BROKER_API_KEY=
# 实盘券商（在 broker_live 内对接 API 后启用）
# REAL_BROKER_BASE_URL=
# REAL_BROKER_API_KEY=

# 新闻/行情缓存 TTL（秒），0=不缓存
# CACHE_TTL_SECONDS=60
# 单次请求最大标的数
# MAX_SYMBOLS_PER_REQUEST=20
# 大盘指数代码（默认沪深300）
# DEFAULT_INDEX_SYMBOL=399300

# 日报推送中的图表链接根地址（如 http://your-server:8000），配置后推送内容会带各标的图表链接
# PUBLIC_BASE_URL=http://localhost:8000
